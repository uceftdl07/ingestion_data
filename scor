def _fetch_schedule_status(client: Any, rid: str) -> dict[str, str]:
    """
    Fetch the current run status for a Foundry schedule RID.

    Priority strategy:
      1. Try the typed SDK client (foundry-platform-python ≥ 2.x)
      2. Fall back to REST API if the SDK method doesn't exist
      3. Return API_ERROR on any exception so the job never hard-crashes

    Returns a dict with keys: status_key, status_label, emoji, color
    """
    raw_status = "UNKNOWN"
    try:
        # ── Strategy 1: SDK (preferred) ──
        # The SDK exposes .schedules on the platform client since platform SDK v2.
        # Adjust the attribute path if your Foundry stack uses a different SDK version.
        schedule_obj = client.schedules.Schedule.get(rid)

        # The SDK may expose the status under different attribute names depending
        # on the SDK version — we try the most common ones defensively.
        for attr in ("current_run_status", "status", "lastRunStatus"):
            val = getattr(schedule_obj, attr, None)
            if val:
                raw_status = str(val).upper()
                break

    except AttributeError:
        # ── Strategy 2: REST fallback ──
        # This path is used if the SDK doesn't expose .schedules yet.
        # Replace <your-stack> with your actual Foundry hostname.
        log.warning("SDK .schedules not available — falling back to REST for %s", rid)
        try:
            headers = {"Authorization": f"Bearer {client.auth_token}"}
            resp = requests.get(
                f"https://<your-stack>.palantirfoundry.com/scheduler/api/schedules/{rid}",
                headers=headers,
                timeout=REQUEST_TIMEOUT_SECS,
            )
            resp.raise_for_status()
            data = resp.json()
            raw_status = str(
                data.get("currentRunStatus") or data.get("status") or "UNKNOWN"
            ).upper()
        except Exception as rest_err:
            log.error("REST fallback failed for %s: %s", rid, rest_err)
            raw_status = "API_ERROR"

    except Exception as sdk_err:
        log.error("SDK error for %s: %s", rid, sdk_err)
        raw_status = "API_ERROR"

    meta = STATUS_MAP.get(raw_status, STATUS_MAP["UNKNOWN"])
    return {
        "status_key":   raw_status,
        "status_label": meta["label"],
        "emoji":        meta["emoji"],
        "color":        meta["color"],
    }


def _build_teams_payload(
    results: list[dict],
    run_ts: str,
) -> dict:
    """
    Build a rich Microsoft Teams Adaptive Card payload.

    Layout:
      ┌─────────────────────────────────────────────────────┐
      │  📊 Foundry Pipeline Health Check                   │
      │  Last run: 2025-06-25 14:32 UTC                     │
      ├─────────────────────────────────────────────────────┤
      │  ✅ 17  ❌ 2  🔄 1  ⛔ 1                            │
      ├─────────────────────────────────────────────────────┤
      │  Ingest — SQS Raw           ✅ Succeeded            │
      │  DLT — RAW → CURATED        ❌ Failed               │
      │  ...                                                 │
      └─────────────────────────────────────────────────────┘
    """
    # ── Summary counters ──
    counts: dict[str, int] = {k: 0 for k in STATUS_MAP}
    for r in results:
        counts[r["status_key"]] = counts.get(r["status_key"], 0) + 1

    total     = len(results)
    succeeded = counts.get("SUCCEEDED", 0)
    failed    = counts.get("FAILED", 0)
    running   = counts.get("RUNNING", 0)
    errors    = counts.get("API_ERROR", 0)

    # Overall header color: green if all good, red if any failure/error
    header_color = "Good" if (failed + errors) == 0 else "Attention"

    # ── Summary line ──
    summary_parts = []
    if succeeded: summary_parts.append(f"✅ {succeeded} succeeded")
    if failed:    summary_parts.append(f"❌ {failed} failed")
    if running:   summary_parts.append(f"🔄 {running} running")
    if errors:    summary_parts.append(f"⚠️ {errors} API errors")
    other = total - succeeded - failed - running - errors
    if other:     summary_parts.append(f"❓ {other} other")
    summary_line = "  |  ".join(summary_parts) or "No data"

    # ── Per-pipeline FactSet rows ──
    facts = [
        {
            "title": r["label"],
            "value": f"{r['emoji']} {r['status_label']}",
        }
        for r in results
    ]

    payload = {
        "type": "message",
        "attachments": [
            {
                "contentType": "application/vnd.microsoft.card.adaptive",
                "content": {
                    "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
                    "type":    "AdaptiveCard",
                    "version": "1.4",
                    "body": [
                        # ── Title ──
                        {
                            "type":   "TextBlock",
                            "text":   "📊 Foundry Pipeline Health Check",
                            "weight": "Bolder",
                            "size":   "Large",
                            "color":  header_color,
                        },
                        # ── Timestamp ──
                        {
                            "type":     "TextBlock",
                            "text":     f"🕐 Last run: **{run_ts} UTC**  —  {total} pipelines monitored",
                            "isSubtle": True,
                            "wrap":     True,
                        },
                        # ── Divider ──
                        {"type": "Separator"},
                        # ── Summary counts ──
                        {
                            "type":   "TextBlock",
                            "text":   summary_line,
                            "weight": "Bolder",
                            "wrap":   True,
                        },
                        # ── Divider ──
                        {"type": "Separator"},
                        # ── Per-pipeline detail ──
                        {
                            "type":  "TextBlock",
                            "text":  "Pipeline status details:",
                            "weight": "Bolder",
                        },
                        {
                            "type":  "FactSet",
                            "facts": facts,
                        },
                    ],
                    # ── Action: open Foundry ──
                    "actions": [
                        {
                            "type":  "Action.OpenUrl",
                            "title": "🔗 Open Foundry",
                            "url":   "https://<your-stack>.palantirfoundry.com",
                        }
                    ],
                },
            }
        ],
    }

    return payload


def _post_to_teams(payload: dict) -> None:
    """POST the Adaptive Card payload to the Teams webhook. Raises on failure."""
    try:
        response = requests.post(
            TEAMS_WEBHOOK_URL,
            data=json.dumps(payload),
            headers={"Content-Type": "application/json"},
            timeout=REQUEST_TIMEOUT_SECS,
        )
        response.raise_for_status()
        log.info("Teams notification sent — HTTP %s", response.status_code)
    except requests.exceptions.Timeout:
        raise RuntimeError("Teams webhook request timed out.")
    except requests.exceptions.ConnectionError as ce:
        raise RuntimeError(f"Teams webhook connection error: {ce}")
    except requests.exceptions.HTTPError as he:
        raise RuntimeError(
            f"Teams webhook returned HTTP {he.response.status_code}: {he.response.text}"
        )


