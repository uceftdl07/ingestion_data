#  FOUNDRY TRANSFORM ENTRY POINT
# ══════════════════════════════════════════════════════════════════════════════

@configure(network_policy=NETWORK_POLICY_RID)
@transform(
    processed_out=Output(OUTPUT_PATH),
)
def health_check_and_notify(ctx, processed_out):
    """
    Main Foundry Transform.

    Steps:
      1. Iterate over all monitored schedules and fetch their status.
      2. Build a Teams Adaptive Card with the full status report.
      3. POST to the Teams webhook.
      4. Write a summary DataFrame back to Foundry (satisfies Output requirement).
    """
    run_ts = datetime.now(timezone.utc).strftime("%Y-%m-%d %H:%M")
    client = ctx.foundry_client

    # ── Step 1: Collect statuses ──
    results = []
    for entry in MONITORED_SCHEDULES:
        log.info("Checking schedule: %s (%s)", entry["label"], entry["rid"])
        status_info = _fetch_schedule_status(client, entry["rid"])
        results.append({
            "rid":          entry["rid"],
            "label":        entry["label"],
            **status_info,
        })
        log.info("  → %s", status_info["status_label"])

    # ── Step 2: Build Teams payload ──
    payload = _build_teams_payload(results, run_ts)

    # ── Step 3: Send to Teams ──
    _post_to_teams(payload)

    # ── Step 4: Write summary dataset to Foundry ──
    # This dataset acts as the audit trail for every run.
    rows = [
        (
            run_ts,
            r["rid"],
            r["label"],
            r["status_key"],
            r["status_label"],
        )
        for r in results
    ]

    schema = ["run_timestamp", "schedule_rid", "pipeline_label", "status_key", "status_label"]
    summary_df = ctx.spark.createDataFrame(rows, schema)
    processed_out.write_dataframe(summary_df)

    log.info(
        "Health check complete — %d pipelines checked, results written to Foundry.",
        len(results),
    )
