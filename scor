import requests
from transforms.api import transform, Output

# Configure your egress target in the transform decorator if necessary
@transform(
    processed_out=Output("/YourSpace/Projects/Build_Monitor/output_log")
)
def check_build_and_notify(ctx, processed_out):
    build_rid = "ri.foundry.main.build.xxxx-xxxx-xxxx"
    
    # 1. Fetch the build status using the Foundry Platform API Client
    client = ctx.foundry_client
    build_response = client.builds.Build.get(build_rid)
    status = build_response.status  # e.g., 'SUCCEEDED', 'FAILED', 'RUNNING'
    
    # 2. Teams Webhook Configuration
    teams_webhook_url = "https://yourcompany.webhook.office.com/webhookb2/..."
    
    # Structure an elegant Teams Adaptive Card
    payload = {
        "type": "message",
        "attachments": [{
            "contentType": "application/vnd.microsoft.card.adaptive",
            "content": {
                "type": "AdaptiveCard",
                "version": "1.4",
                "body": [
                    {"type": "TextBlock", "text": "Foundry Build Status Update", "weight": "Bolder", "size": "Medium"},
                    {"type": "FactSet", "facts": [
                        {"title": "Build RID:", "value": build_rid},
                        {"title": "Status:", "value": status}
                    ]}
                ]
            }
        }]
    }
    
    # 3. Post to Teams
    response = requests.post(teams_webhook_url, json=payload)
    if response.status_code != 200:
        raise ValueError(f"Failed to send Teams notification: {response.text}")
        
    # Write dummy log to satisfy transform requirements
    # ...
